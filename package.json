{
  "name": "simplehost-source",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "tsc -b tsconfig.json",
    "build:clean-room": "pnpm clean && pnpm build",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean && find . -name '*.tsbuildinfo' -delete",
    "start:control:api": "pnpm --dir apps/control/api start",
    "start:control:web": "pnpm --dir apps/control/web start",
    "start:control:split": "pnpm --dir apps/control start:split",
    "start:control:combined": "pnpm --dir apps/control start:combined",
    "start:control:candidate": "pnpm --dir apps/control start:candidate",
    "start:control:combined:dev": "pnpm --dir apps/control start:combined:dev",
    "start:control:combined:smoke": "pnpm --dir apps/control start:combined:smoke",
    "dev:control:combined": "pnpm --dir apps/control dev:combined",
    "pack:control:release-sandbox": "pnpm --dir apps/control pack:release-sandbox",
    "start:control:release-sandbox": "pnpm --dir apps/control start:release-sandbox",
    "pack:control:release-shadow": "pnpm --dir apps/control pack:release-shadow",
    "start:control:release-shadow": "pnpm --dir apps/control start:release-shadow",
    "inspect:control:release-shadow": "pnpm --dir apps/control inspect:release-shadow",
    "plan:control:release-root-staging": "pnpm --dir apps/control plan:release-root-staging",
    "diff:control:release-root-staging": "pnpm --dir apps/control diff:release-root-staging",
    "apply:control:release-root-staging": "pnpm --dir apps/control apply:release-root-staging",
    "inspect:control:release-root-staging": "pnpm --dir apps/control inspect:release-root-staging",
    "start:control:release-root-staging": "pnpm --dir apps/control start:release-root-staging",
    "plan:control:release-root-promotion": "pnpm --dir apps/control plan:release-root-promotion",
    "diff:control:release-root-promotion": "pnpm --dir apps/control diff:release-root-promotion",
    "apply:control:release-root-promotion": "pnpm --dir apps/control apply:release-root-promotion",
    "inspect:control:release-root-promotion": "pnpm --dir apps/control inspect:release-root-promotion",
    "start:control:release-root-promotion": "pnpm --dir apps/control start:release-root-promotion",
    "activate:control:release-root-promotion": "pnpm --dir apps/control activate:release-root-promotion",
    "promote:control:release-root-promotion": "pnpm --dir apps/control promote:release-root-promotion",
    "promotion-ready:control:release-root-promotion": "pnpm --dir apps/control promotion-ready:release-root-promotion",
    "plan:control:release-root-cutover": "pnpm --dir apps/control plan:release-root-cutover",
    "inspect:control:release-root-cutover": "pnpm --dir apps/control inspect:release-root-cutover",
    "cutover-ready:control:release-root-cutover": "pnpm --dir apps/control cutover-ready:release-root-cutover",
    "promotion-ready:control:release-shadow": "pnpm --dir apps/control promotion-ready:release-shadow",
    "apply:control:release-target": "pnpm --dir apps/control apply:release-target",
    "start:control:release-target": "pnpm --dir apps/control start:release-target",
    "handoff:control:release-shadow": "pnpm --dir apps/control release-handoff",
    "rehearse:control:release-shadow": "pnpm --dir apps/control release-rehearsal",
    "activate:control:release-sandbox": "pnpm --dir apps/control activate:release-sandbox",
    "inspect:control:release-sandbox": "pnpm --dir apps/control inspect:release-sandbox",
    "promote:control:release-sandbox": "pnpm --dir apps/control promote:release-sandbox",
    "promotion-ready:control:release-sandbox": "pnpm --dir apps/control promotion-ready",
    "start:worker": "pnpm --filter @simplehost/panel-worker start",
    "start:agent": "pnpm --filter @simplehost/manager-agent start",
    "start:cli": "pnpm --filter @simplehost/manager-cli start",
    "test": "pnpm -r --if-present test",
    "build:control": "tsc -b apps/control/tsconfig.json",
    "typecheck:control": "pnpm --dir apps/control typecheck:local",
    "build:panel-runtime": "tsc -b tsconfig.panel.json",
    "build:manager-runtime": "tsc -b tsconfig.manager.json",
    "typecheck:panel-runtime": "pnpm --filter @simplehost/panel-config typecheck && pnpm --filter @simplehost/panel-contracts typecheck && pnpm --filter @simplehost/panel-testing typecheck && pnpm --filter @simplehost/panel-ui typecheck && pnpm --filter @simplehost/panel-database typecheck && pnpm --dir apps/control typecheck:local && pnpm --filter @simplehost/panel-worker typecheck",
    "typecheck:manager-runtime": "pnpm --filter @simplehost/manager-contracts typecheck && pnpm --filter @simplehost/manager-node-config typecheck && pnpm --filter @simplehost/manager-testing typecheck && pnpm --filter @simplehost/manager-control-plane-client typecheck && pnpm --filter @simplehost/manager-renderers typecheck && pnpm --filter @simplehost/manager-drivers typecheck && pnpm --filter @simplehost/manager-agent typecheck && pnpm --filter @simplehost/manager-cli typecheck",
    "build:control:api": "pnpm --dir apps/control build:api",
    "build:control:web": "pnpm --dir apps/control build:web",
    "typecheck:control:api": "pnpm --dir apps/control typecheck:api",
    "typecheck:control:web": "pnpm --dir apps/control typecheck:web",
    "audit:legacy-roots": "node scripts/audit-legacy-roots.mjs",
    "build:control:shared": "pnpm --dir apps/control build:shared",
    "typecheck:control:shared": "pnpm --dir apps/control typecheck:shared",
    "start:control": "pnpm --dir apps/control start:combined",
    "test:control": "pnpm --dir apps/control test:entrypoint",
    "test:control:candidate": "pnpm --dir apps/control test:candidate",
    "test:control:combined-smoke": "pnpm --dir apps/control test:combined-smoke",
    "test:control:combined:e2e": "pnpm --dir apps/control test:combined:e2e",
    "test:control:preflight": "pnpm --dir apps/control test:preflight",
    "test:control:release-candidate": "pnpm --dir apps/control test:release-candidate",
    "test:control:promotion-ready": "pnpm --dir apps/control test:release-sandbox:promotion-ready",
    "test:control:bundle-parity": "pnpm --dir apps/control test:release-sandbox:bundle-parity",
    "test:control:release-sandbox": "pnpm --dir apps/control test:release-sandbox",
    "test:control:release-shadow": "pnpm --dir apps/control test:release-shadow",
    "test:control:release-root-staging": "pnpm --dir apps/control test:release-root-staging",
    "test:control:release-root-promotion": "pnpm --dir apps/control test:release-root-promotion",
    "test:control:release-root-promotion:activation": "pnpm --dir apps/control test:release-root-promotion:activation",
    "test:control:release-root-promotion:promotion": "pnpm --dir apps/control test:release-root-promotion:promotion",
    "test:control:release-root-promotion:ready": "pnpm --dir apps/control test:release-root-promotion:ready",
    "test:control:release-root-cutover": "pnpm --dir apps/control test:release-root-cutover",
    "test:control:release-target": "pnpm --dir apps/control test:release-target",
    "test:control:release-handoff": "pnpm --dir apps/control test:release-handoff",
    "test:control:release-rehearsal": "pnpm --dir apps/control test:release-rehearsal",
    "test:control:runtime-parity": "pnpm --dir apps/control test:runtime-parity",
    "test:control:parity": "pnpm --dir apps/control test:parity",
    "check:control:candidate": "pnpm --dir apps/control check:candidate",
    "check:control:preflight": "pnpm --dir apps/control check:preflight",
    "check:control:release-candidate": "pnpm --dir apps/control check:release-candidate",
    "check:control:promotion-ready": "pnpm --dir apps/control check:release-sandbox:promotion-ready",
    "check:control:bundle-parity": "pnpm --dir apps/control check:release-sandbox:bundle-parity",
    "check:control:release-sandbox": "pnpm --dir apps/control check:release-sandbox",
    "check:control:release-shadow": "pnpm --dir apps/control check:release-shadow",
    "check:control:release-root-staging": "pnpm --dir apps/control check:release-root-staging",
    "check:control:release-root-promotion": "pnpm --dir apps/control check:release-root-promotion",
    "check:control:release-root-cutover": "pnpm --dir apps/control check:release-root-cutover",
    "check:control:release-target": "pnpm --dir apps/control check:release-target",
    "check:control:release-handoff": "pnpm --dir apps/control check:release-handoff",
    "check:control:release-rehearsal": "pnpm --dir apps/control check:release-rehearsal",
    "test:control:release-shadow:promotion-ready": "pnpm --dir apps/control test:release-shadow:promotion-ready",
    "test:control:web": "pnpm --dir apps/control test:web",
    "build:control:entrypoint": "pnpm --dir apps/control build:entrypoint",
    "typecheck:control:entrypoint": "pnpm --dir apps/control typecheck:entrypoint"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.18.0",
    "typescript": "^5.8.3"
  }
}
