{
  "name": "simplehost-source",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "tsc -b tsconfig.json",
    "build:clean-room": "pnpm clean && pnpm build",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean && find . -name '*.tsbuildinfo' -delete",
    "start:control:api": "pnpm --dir apps/control/api start",
    "start:control:web": "pnpm --dir apps/control/web start",
    "start:worker": "pnpm --filter @simplehost/panel-worker start",
    "start:agent": "pnpm --filter @simplehost/manager-agent start",
    "start:cli": "pnpm --filter @simplehost/manager-cli start",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.18.0",
    "typescript": "^5.8.3"
  }
}
