{
  "name": "simplehost-manager",
  "version": "2603.12.07",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "pnpm --filter @simplehost/manager-contracts build && pnpm --filter @simplehost/manager-control-plane-client build && pnpm --filter @simplehost/manager-node-config build && pnpm --filter @simplehost/manager-renderers build && pnpm --filter @simplehost/manager-testing build && pnpm --filter @simplehost/manager-drivers build && pnpm --filter @simplehost/manager-agent build && pnpm --filter @simplehost/manager-cli build",
    "bundle:release": "./scripts/build-release-bundle.sh",
    "install:bundle": "./scripts/install-bundle.sh",
    "release:rollback": "./scripts/rollback-release.sh",
    "version:set": "node scripts/set-version.mjs",
    "version:today": "node scripts/set-version.mjs --today",
    "start:agent": "pnpm build && node apps/agent/dist/index.js",
    "start:cli": "pnpm build && node apps/cli/dist/index.js",
    "install:deps": "./scripts/install-system-deps-almalinux.sh",
    "bootstrap:workspace": "./scripts/bootstrap-workspace-repos.sh",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.18.0",
    "typescript": "^5.8.3"
  }
}
