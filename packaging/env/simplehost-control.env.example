NODE_ENV=development
SIMPLEHOST_VERSION=2604.20.12
SIMPLEHOST_CONTROL_RUNTIME_MODE=combined

SIMPLEHOST_API_HOST=127.0.0.1
SIMPLEHOST_API_PORT=3200
SIMPLEHOST_WEB_HOST=127.0.0.1
SIMPLEHOST_WEB_PORT=3200

SIMPLEHOST_DATABASE_URL=postgresql://simplehost_control:change-me@127.0.0.1:5433/simplehost_control
SIMPLEHOST_BOOTSTRAP_ENROLLMENT_TOKEN=change-me
SIMPLEHOST_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SIMPLEHOST_BOOTSTRAP_ADMIN_PASSWORD=change-me
SIMPLEHOST_BOOTSTRAP_ADMIN_NAME=SimpleHost Admin
SIMPLEHOST_SESSION_TTL_SECONDS=43200
SIMPLEHOST_INVENTORY_PATH=/etc/simplehost/inventory.apps.yaml
SIMPLEHOST_JOB_SECRET_KEY=change-me
