NODE_ENV=development
SHP_VERSION=2604.19.06
SIMPLEHOST_CONTROL_RUNTIME_MODE=combined

SHP_API_HOST=127.0.0.1
SHP_API_PORT=3200
SHP_WEB_HOST=127.0.0.1
SHP_WEB_PORT=3200

SHP_DATABASE_URL=postgresql://simplehost_panel:change-me@127.0.0.1:5433/simplehost_panel
SHP_BOOTSTRAP_ENROLLMENT_TOKEN=change-me
SHP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SHP_BOOTSTRAP_ADMIN_PASSWORD=change-me
SHP_BOOTSTRAP_ADMIN_NAME=SimpleHost Admin
SHP_SESSION_TTL_SECONDS=43200
SHP_INVENTORY_PATH=/etc/simplehost/inventory.apps.yaml
SHP_JOB_SECRET_KEY=change-me
