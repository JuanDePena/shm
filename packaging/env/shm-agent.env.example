NODE_ENV=development
SHM_VERSION=2603.12.06
SHM_NODE_ID=primary
SHM_HOSTNAME=primary.internal.simplehost
SHM_CONTROL_PLANE_URL=http://127.0.0.1:3100
SHM_ENROLLMENT_TOKEN=change-me-enrollment-token
SHM_CONFIG_PATH=/etc/shm/config.yaml
SHM_STATE_DIR=/var/lib/shm
SHM_LOG_DIR=/var/log/shm
SHM_HEARTBEAT_MS=10000
SHM_HTTPD_SITES_DIR=/etc/httpd/conf.d
SHM_HTTPD_STAGING_DIR=/var/lib/shm/staging/httpd
SHM_PDNS_API_URL=http://127.0.0.1:8081
SHM_PDNS_API_KEY=change-me-pdns-key
SHM_PDNS_SERVER_ID=localhost
SHM_PDNS_STAGING_DIR=/var/lib/shm/staging/pdns
SHM_POSTGRES_ADMIN_URL=
SHM_MARIADB_ADMIN_URL=
