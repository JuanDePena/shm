[Unit]
Description=SimpleHost Panel Worker
After=network-online.target postgresql@shp.service
Wants=network-online.target
Requires=postgresql@shp.service

[Service]
Type=simple
User=spanel
Group=spanel
WorkingDirectory=/opt/simplehostman/release/current
EnvironmentFile=/etc/spanel/worker.env
ExecStart=/usr/bin/node /opt/simplehostman/release/current/apps/worker/dist/index.js
Restart=always
RestartSec=5
StateDirectory=spanel
LogsDirectory=spanel

[Install]
WantedBy=multi-user.target
