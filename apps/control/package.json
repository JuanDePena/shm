{
  "name": "@simplehost/control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:shared": "pnpm --dir shared build",
    "build:api": "pnpm --dir api build",
    "build:web": "pnpm --dir web build",
    "build:entrypoint": "tsc -b tsconfig.entrypoint.json",
    "build": "tsc -b tsconfig.json",
    "clean:shared": "pnpm --dir shared clean",
    "clean:api": "pnpm --dir api clean",
    "clean:web": "pnpm --dir web clean",
    "clean:entrypoint": "rm -rf dist",
    "clean": "pnpm clean:shared && pnpm clean:api && pnpm clean:web && pnpm clean:entrypoint",
    "start:api": "pnpm --dir api start",
    "start:web": "pnpm --dir web start",
    "start:split": "pnpm start:api & pnpm start:web",
    "start:split:foreground": "pnpm start:api && pnpm start:web",
    "start:combined": "node dist/index.js",
    "start:candidate": "pnpm start:combined",
    "start:combined:dev": "pnpm build:entrypoint && SIMPLEHOST_CONTROL_RUNTIME_MODE=combined node dist/index.js",
    "start:combined:smoke": "pnpm start:combined:dev",
    "dev:combined": "pnpm start:combined:dev",
    "pack:release-sandbox": "pnpm build:entrypoint && node dist/release-sandbox-pack-cli.js",
    "start:release-sandbox": "pnpm build:entrypoint && node dist/release-sandbox-start-cli.js",
    "activate:release-sandbox": "pnpm build:entrypoint && node dist/release-sandbox-activate-cli.js",
    "inspect:release-sandbox": "pnpm build:entrypoint && node dist/release-sandbox-inspect-cli.js",
    "preflight": "pnpm build:entrypoint && node dist/preflight-cli.js",
    "release-candidate": "pnpm build:entrypoint && node dist/release-candidate-cli.js",
    "check:preflight": "pnpm typecheck:local && pnpm preflight && pnpm test:preflight",
    "check:release-candidate": "pnpm typecheck:local && pnpm release-candidate && pnpm test:release-candidate",
    "check:release-sandbox:bundle-parity": "pnpm typecheck:local && pnpm test:release-sandbox:bundle-parity",
    "check:release-sandbox": "pnpm typecheck:local && pnpm pack:release-sandbox && pnpm test:release-sandbox && pnpm test:release-sandbox:bundle-parity && node dist/release-sandbox-inspect-cli.js",
    "check:candidate": "pnpm typecheck:local && pnpm test:parity && pnpm test:runtime-parity && pnpm test:combined-smoke && pnpm test:combined:e2e && pnpm check:preflight && pnpm check:release-candidate && pnpm check:release-sandbox",
    "test:entrypoint": "pnpm build:entrypoint && node --test dist/**/*.test.js",
    "test:combined-smoke": "pnpm build:entrypoint && node --test dist/combined-smoke.test.js",
    "test:combined:e2e": "pnpm build:entrypoint && node --test dist/combined-server.test.js",
    "test:preflight": "pnpm build:entrypoint && node --test dist/preflight-runner.test.js",
    "test:release-candidate": "pnpm build:entrypoint && node --test dist/release-candidate-runner.test.js",
    "test:release-sandbox:bundle-parity": "pnpm build:entrypoint && node --test dist/release-sandbox-bundle-parity.test.js",
    "test:release-sandbox": "pnpm build:entrypoint && node --test dist/release-sandbox-smoke.test.js dist/release-sandbox-parity.test.js dist/release-sandbox-activation.test.js",
    "test:runtime-parity": "pnpm build:entrypoint && node --test dist/runtime-parity.test.js",
    "test:parity": "pnpm test:entrypoint",
    "test:candidate": "pnpm test:runtime-parity && pnpm test:combined-smoke && pnpm test:combined:e2e",
    "test:web": "pnpm --dir web test",
    "test": "pnpm test:entrypoint",
    "typecheck:shared": "pnpm --dir shared typecheck",
    "typecheck:api": "pnpm --dir api typecheck",
    "typecheck:web": "pnpm --dir web typecheck",
    "typecheck:entrypoint": "tsc -b tsconfig.entrypoint.json",
    "typecheck:local": "pnpm typecheck:shared && pnpm typecheck:api && pnpm typecheck:web && pnpm typecheck:entrypoint"
  },
  "description": "Unified control-plane source boundary with transitional API and web entrypoints",
  "dependencies": {
    "@simplehost/control-api": "workspace:*",
    "@simplehost/control-shared": "workspace:*",
    "@simplehost/control-web": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ]
}
